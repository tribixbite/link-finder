{
  "name": "findur-link",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun ./scripts/vite-cli.ts dev",
    "build": "bun ./scripts/vite-cli.ts build",
    "preview": "bun ./scripts/vite-cli.ts preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "api": "bun ./scripts/api-server.ts",
    "postinstall": "sh postinstall.sh",
    "publish": "cd packages/findurlink && npm publish"
  },
  "devDependencies": {
    "@rollup/rollup-android-arm64": "4.59.0",
    "@rollup/wasm-node": "4.59.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "4.2.1",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "tailwindcss": "^4.0.0"
  },
  "type": "module"
}
